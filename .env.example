# =============================================================================
# Multi-Tenant Turso (LibSQL) Database Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# 1. MASTER DATABASE (Turso)
# -----------------------------------------------------------------------------
# The Master DB stores project metadata and tenant database credentials.
# Create this database first in Turso dashboard, then copy the connection details.

TURSO_MASTER_DB_URL=libsql://your-master-db-name-yourorg.turso.io
TURSO_MASTER_DB_TOKEN=your-master-db-auth-token

# -----------------------------------------------------------------------------
# 2. TURSO PLATFORM API (Required for programmatic DB creation)
# -----------------------------------------------------------------------------
# Get your Platform API token from: https://app.turso.tech/organizations/your-org/settings/api-tokens
# This is DIFFERENT from the DB token - it allows creating/managing databases.

TURSO_PLATFORM_API_TOKEN=your-platform-api-token-from-turso-dashboard
TURSO_ORGANIZATION=your-organization-name

# Optional: Group name for organizing tenant databases
TURSO_GROUP=tenant-databases

# Optional: Primary location for new databases (default: sin = Singapore)
# Available locations: https://docs.turso.tech/introduction#locations
TURSO_LOCATION=sin

# -----------------------------------------------------------------------------
# 3. LOCAL DEVELOPMENT (Fallback when Turso env vars are not set)
# -----------------------------------------------------------------------------
# When Turso env vars are missing, the app uses local SQLite files:
# - Master DB: ./db/projects.db
# - Tenant DBs: ./db/notes/note-{slug}.db
# No additional configuration needed for local dev.

# -----------------------------------------------------------------------------
# 4. APPLICATION SETTINGS
# -----------------------------------------------------------------------------
# Session secret for auth (use random string)
SESSION_SECRET=your-random-session-secret-min-32-chars

# Optional: Admin credentials for local development
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# =============================================================================
# SETUP INSTRUCTIONS:
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Get Turso Platform API Token:
#    - Go to https://app.turso.tech
#    - Navigate to your organization Settings > API Tokens
#    - Create a new token with "Databases" permission
#
# 3. Create Master Database:
#    turso db create master-db
#    turso db tokens create master-db
#    # Copy the URL and token to TURSO_MASTER_DB_URL and TURSO_MASTER_DB_TOKEN
#
# 4. Install dependencies:
#    bun install
#
# 5. Run migrations:
#    bun run dbmig
#
# 6. Start development server:
#    bun run dev
#
# =============================================================================
