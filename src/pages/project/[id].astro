---
import Layout from '../../layouts/Layout.astro';
import AdminNotes from '../../components/vue/AdminNotes.vue';
import ThemeToggle from '../../components/vue/ThemeToggle.vue';
import Toast from '../../components/vue/Toast.vue';
import { getProjectById } from '../../lib/query';

// Check auth
const sessionCookie = Astro.cookies.get('session');
if (!sessionCookie) {
  return Astro.redirect('/login');
}

const user = JSON.parse(sessionCookie.value);

const { id } = Astro.params;
const projectId = Number(id);

if (!id || isNaN(projectId)) {
  return Astro.redirect('/');
}

const project = await getProjectById(projectId);

if (!project) {
  return Astro.redirect('/');
}

const statusLabels: Record<string, string> = {
  draft: 'Draft',
  review: 'Review',
  done: 'Done',
};

const statusDescriptions: Record<string, string> = {
  draft: 'Project is in preparation phase',
  review: 'Project is ready for review',
  done: 'Project has been completed',
};

const shareUrl = `${Astro.url.origin}/share/${project.shareToken}`;
---

<Layout title={`${project.name} | Client Handoff Dashboard`}>
  <div class="admin-portal">
    <div class="header-container">
      <header class="portal-header">
        <div class="brand">
          <span class="logo">Project Manager</span>
          <span class="divider">|</span>
          <span class="portal-name">Admin Dashboard</span>
        </div>
        <div class="header-actions">
          <span class="user-name">{user.name}</span>
          <ThemeToggle client:load />
          <button id="logout-btn" class="btn-logout" title="Logout">
            <i class="fa-solid fa-sign-out-alt"></i>
          </button>
        </div>
      </header>
    </div>

    <main class="portal-content">
      <div class="project-card">
        <div class="project-header">
          <div class="project-meta">
            <span class="client-label">Client</span>
            <h1 class="project-name">{project.name}</h1>
            <p class="client-name">{project.client}</p>
            {project.description && <p class="project-description">{project.description}</p>}
          </div>
          <div class="status-section">
            <span class={`status-badge ${project.status}`}>
              {statusLabels[project.status]}
            </span>
            <p class="status-desc">{statusDescriptions[project.status]}</p>
          </div>
        </div>

        <div class="actions-section">
          <h3>Update Status</h3>
          <p class="action-hint">Click to change project status:</p>
          <div class="status-buttons">
            <button
              class={`btn-status ${project.status === 'draft' ? 'active' : ''}`}
              data-status="draft"
              data-id={project.id}
            >
              <i class="fa-solid fa-pen-to-square"></i> Draft
            </button>
            <button
              class={`btn-status ${project.status === 'review' ? 'active' : ''}`}
              data-status="review"
              data-id={project.id}
            >
              <i class="fa-solid fa-eye"></i> Review
            </button>
            <button
              class={`btn-status ${project.status === 'done' ? 'active' : ''}`}
              data-status="done"
              data-id={project.id}
            >
              <i class="fa-solid fa-check-double"></i> Done
            </button>
          </div>
        </div>

        <div class="share-section">
          <h3>Secret Link</h3>
          <p class="share-hint">Send this link to client via WhatsApp:</p>
          <div class="share-link-box">
            <input type="text" value={shareUrl} readonly id="admin-share-url" />
            <button class="btn-copy" id="admin-copy-btn">
              <i class="fa-regular fa-copy"></i>
              Copy
            </button>
          </div>
        </div>
      </div>

      <div class="discussion-card">
        <AdminNotes projectId={projectId} slug={project.slug} client:load />
      </div>
    </main>
    
    <!-- Toast Container - client:only karena pakai Teleport -->
    <Toast client:only="vue" position="top-right" />

    <footer class="portal-footer">
      <p>Powered by <strong>Vendaar</strong> — Known for being a reliable partner</p>
    </footer>
  </div>
</Layout>

<script>
  document.querySelectorAll('.btn-status').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const status = (e.currentTarget as HTMLElement).dataset.status;
      const id = (e.currentTarget as HTMLElement).dataset.id;

      try {
        const response = await fetch('/api/projects', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(id), status }),
        });

        if (response.ok) {
          window.location.reload();
        }
      } catch (err) {
        console.error('Failed to update status:', err);
      }
    });
  });

  // Copy share link
  const adminCopyBtn = document.getElementById('admin-copy-btn');
  const adminShareUrl = document.getElementById('admin-share-url') as HTMLInputElement;

  adminCopyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(adminShareUrl.value);
      adminCopyBtn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
      setTimeout(() => {
        adminCopyBtn.innerHTML = '<i class="fa-regular fa-copy"></i> Copy';
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    try {
      const response = await fetch('/api/auth/logout', { method: 'POST' });
      if (response.ok) {
        window.location.href = '/login';
      }
    } catch (err) {
      console.error('Logout failed:', err);
    }
  });
</script>

<style>
  .admin-portal {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
  }

  .header-container {
    width: 100%;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .portal-header {
    max-width: 800px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text);
  }

  .divider {
    color: var(--color-text-muted);
  }

  .portal-name {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .header-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .user-name {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .btn-logout {
    width: 30px;
    height: 30px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-logout:hover {
    background: var(--color-error);
    color: var(--color-bg);
    border-color: var(--color-error);
  }

  .portal-content {
    flex: 1;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
}

  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .discussion-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    min-height: 400px;
  }

  .portal-footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .portal-footer strong {
    color: var(--color-text);
  }

  .portal-footer p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 640px) {
    .brand {
      gap: 0.5rem;
    }

    .brand .divider,
    .brand .portal-name {
      display: none;
    }

    .header-actions {
      gap: 0.5rem;
    }

    .user-name {
      font-size: 0.875rem;
      max-width: 100px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .btn-logout {
      padding: 0.5rem;
    }

    .project-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .status-section {
      text-align: left;
      width: 100%;
    }

    .share-link-box {
      flex-direction: column;
    }
  }

  .project-detail {
    display: none;
  }

  .project-meta {
    flex: 1;
  }

  .client-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .project-name {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0.25rem 0 0.5rem;
  }

  .client-name {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }

  .project-description {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  .status-section {
    text-align: right;
  }

  .status-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.draft {
    background: var(--color-status-draft-bg);
    color: var(--color-status-draft-text);
  }

  .status-badge.review {
    background: var(--color-status-review-bg);
    color: var(--color-status-review-text);
  }

  .status-badge.done {
    background: var(--color-status-done-bg);
    color: var(--color-status-done-text);
  }

  .status-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .actions-section {
    margin-bottom: 1.5rem;
  }

  .actions-section h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .action-hint {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .share-section {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .share-section h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .share-hint {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .share-link-box {
    display: flex;
    gap: 0.75rem;
  }

  .share-link-box input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.9375rem;
    font-family: monospace;
  }

  .btn-copy {
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s;
  }

  .btn-copy:hover {
    border-color: var(--color-border-hover);
  }

  .btn-copy.copied {
    color: var(--color-success);
    border-color: var(--color-success);
  }

  .btn-copy i {
    margin-right: 0.375rem;
  }

  .status-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-status {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-status:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  .btn-status.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-bg);
  }

  .btn-status i {
    margin-right: 0.375rem;
  }
</style>
