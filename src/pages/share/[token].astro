---
import Layout from '../../layouts/Layout.astro';
import ClientNotes from '../../components/vue/ClientNotes.vue';
import ThemeToggle from '../../components/vue/ThemeToggle.vue';
import Toast from '../../components/vue/Toast.vue';
import { getProjectByShareToken } from '../../lib/query';

const { token: shareToken } = Astro.params;

if (!shareToken) {
  return Astro.redirect('/');
}

const project = await getProjectByShareToken(shareToken);

if (!project) {
  return Astro.redirect('/');
}

const statusLabels: Record<string, string> = {
  draft: 'Draft',
  review: 'Review',
  done: 'Done',
};

const statusDescriptions: Record<string, string> = {
  draft: 'Project is in preparation phase',
  review: 'Project is ready for review',
  done: 'Project has been completed',
};

const shareUrl = `${Astro.url.origin}/share/${shareToken}`;
---

<Layout title={`${project.name} | Vendaar Client Portal`}>
  <div class="client-portal">
    <div class="header-container">
      <header class="portal-header">
        <div class="brand">
          <span class="logo">Project Manager</span>
          <span class="divider">|</span>
          <span class="portal-name">Client Portal</span>
        </div>
        <ThemeToggle client:load />
      </header>
    </div>

    <main class="portal-content">
      <div class="project-card">
        <div class="project-header">
          <div class="project-meta">
            <span class="client-label">Client</span>
            <h1 class="project-name">{project.name}</h1>
            <p class="client-name">{project.client}</p>
            {project.description && <p class="project-description">{project.description}</p>}
          </div>
          <div class="status-section">
            <span class={`status-badge ${project.status}`}>
              {statusLabels[project.status]}
            </span>
            <p class="status-desc">{statusDescriptions[project.status]}</p>
          </div>
        </div>

        <div class="actions-section">
          <h3>Update Status</h3>
          <p class="action-hint">Click to change project status:</p>
          <div class="status-buttons">
            <button
              class={`btn-status ${project.status === 'draft' ? 'active' : ''}`}
              data-status="draft"
              data-token={shareToken}
            >
              <i class="fa-solid fa-pen-to-square"></i> Draft
            </button>
            <button
              class={`btn-status ${project.status === 'review' ? 'active' : ''}`}
              data-status="review"
              data-token={shareToken}
            >
              <i class="fa-solid fa-eye"></i> Review
            </button>
            <button
              class={`btn-status ${project.status === 'done' ? 'active' : ''}`}
              data-status="done"
              data-token={shareToken}
            >
              <i class="fa-solid fa-check-double"></i> Done
            </button>
          </div>
        </div>

        <div class="share-section">
          <h3>Access Link</h3>
          <p class="share-hint">Save this link to access the project anytime:</p>
          <div class="share-link-box">
            <input type="text" value={shareUrl} readonly id="share-url" />
            <button class="btn-copy" id="copy-btn">
              <i class="fa-regular fa-copy"></i>
              Copy
            </button>
          </div>
        </div>
      </div>

      <div class="discussion-section">
        <ClientNotes shareToken={shareToken} client:load />
      </div>
    </main>
    
    <!-- Toast Container - client:only karena pakai Teleport -->
    <Toast client:only="vue" position="top-center" />

    <footer class="portal-footer">
      <p>Powered by <strong>Vendaar</strong> — Design-driven frontend partner</p>
    </footer>
  </div>
</Layout>

<script>
  // Handle status updates
  document.querySelectorAll('.btn-status').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const status = (e.currentTarget as HTMLElement).dataset.status;
      const token = (e.currentTarget as HTMLElement).dataset.token;

      try {
        const response = await fetch('/api/share/status', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, status }),
        });

        if (response.ok) {
          window.location.reload();
        }
      } catch (err) {
        console.error('Failed to update status:', err);
      }
    });
  });

  // Handle copy link
  const copyBtn = document.getElementById('copy-btn');
  const shareUrl = document.getElementById('share-url') as HTMLInputElement;

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(shareUrl.value);
      copyBtn.innerHTML = `
        <i class="fa-solid fa-check"></i>
        Copied!
      `;
      setTimeout(() => {
        copyBtn.innerHTML = `
          <i class="fa-regular fa-copy"></i>
          Copy
        `;
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>

<style>
  .client-portal {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
  }

  .header-container {
    width: 100%;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .portal-header {
    max-width: 800px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text);
  }

  .divider {
    color: var(--color-text-muted);
  }

  .portal-name {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .portal-content {
    flex: 1;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .project-meta {
    flex: 1;
  }

  .client-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .project-name {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0.25rem 0 0.5rem;
  }

  .client-name {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }

  .project-description {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  .status-section {
    text-align: right;
  }

  .status-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.draft {
    background: var(--color-status-draft-bg);
    color: var(--color-status-draft-text);
  }

  .status-badge.review {
    background: var(--color-status-review-bg);
    color: var(--color-status-review-text);
  }

  .status-badge.done {
    background: var(--color-status-done-bg);
    color: var(--color-status-done-text);
  }

  .status-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .actions-section {
    margin-bottom: 1.5rem;
  }

  .actions-section h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .action-hint {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .status-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-status {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-status:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  .btn-status.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-bg);
  }

  .btn-status i {
    margin-right: 0.375rem;
  }

  .share-section {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .share-section h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .share-hint {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .share-link-box {
    display: flex;
    gap: 0.75rem;
  }

  .share-link-box input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.875rem;
  }

  .btn-copy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-copy:hover {
    border-color: var(--color-primary);
    background: var(--color-bg);
  }

  .btn-copy i {
    font-size: 0.875rem;
  }

  .discussion-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    min-height: 400px;
  }

  .portal-footer {
    padding: 1.5rem;
    text-align: center;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .portal-footer p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .portal-footer strong {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .project-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .status-section {
      text-align: left;
      width: 100%;
    }

    .share-link-box {
      flex-direction: column;
    }
  }
</style>
